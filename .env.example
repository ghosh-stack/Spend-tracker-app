# SpendLens — local configuration template.
# Copy to ".env" and fill in. NEVER commit the real .env (it is gitignored).
# Nothing here is required to run the PWA; these only power the optional
# ingestion adapters in /adapters.

# ── Email (IMAP) ingestion adapter ───────────────────────────────────────────
# Use a provider APP PASSWORD, not your main password. For Gmail, create one at
# https://myaccount.google.com/apppasswords (requires 2FA). For Outlook/others,
# use the equivalent app-specific password. No OAuth secrets are hardcoded.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@example.com
IMAP_APP_PASSWORD=
# Comma-separated bank sender domains/addresses to scan (others are ignored).
IMAP_ALLOWED_SENDERS=alerts@hdfcbank.net,no-reply@icicibank.com,donotreply@axisbank.com
# How far back to scan on first run, and poll interval (seconds).
IMAP_SINCE_DAYS=30
IMAP_POLL_SECONDS=120

# ── Local ingest endpoint (used by email + android-sms adapters) ──────────────
# The adapters POST parsed/raw messages to the running app's local ingest.
# Bind to localhost only. The shared token gates writes; generate a random one.
INGEST_URL=http://127.0.0.1:8787/ingest
INGEST_TOKEN=
